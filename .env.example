# Copie este arquivo para .env.local antes de rodar o projeto.

# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://SEU-PROJETO.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=sua-anon-key-aqui
SUPABASE_SERVICE_ROLE_KEY=sua-service-role-key-aqui

# Google Places API
GOOGLE_PLACES_API_KEY=sua-google-api-key-aqui

# AI image generation for hero art (optional)
OPENAI_API_KEY=sua-openai-key-aqui
GEMINI_API_KEY=sua-gemini-key-aqui

# Captura e compartilhamento local
INTERNAL_CAPTURE_ORIGIN=http://127.0.0.1:3000
SCREENSHOT_BROWSER_PATH=
PORT=3000

# Seguranca de API (opcional)
# Por padrao, endpoints sensiveis aceitam apenas requests locais.
ALLOW_NON_LOCAL_API=false
INTERNAL_API_KEY=
