# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/.next-build-check/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*
!.env.example
!.env.local.example

# local app state and generated share data
/data/app-state.json
/data/app-state.backup.json
/data/short-urls.json
/data/tunnel-info.json
/data/tunnel-url.txt
/data/sites/
/data/stitch-*/
/data/stitch-*.html
/data/stitch-*.png

# local tool and test artifacts
/.mcp.json
/.sp-test.txt
/.spawn-test.txt

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# local tooling artifacts
.codex-*
tmp-stitch-*
tmp-screenshot-check.png
